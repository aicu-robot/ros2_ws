<?xml version="1.0" encoding="utf-8"?>
<robot name="fw_mini" xmlns:xacro="http://www.ros.org/wiki/xacro">

  <!-- 메시 파일 절대경로 (Gazebo 렌더러가 package:// 를 못 찾는 문제 우회) -->
  <xacro:property name="mesh_path" value="file://$(find fw_mini_description)/meshes"/>

  <!-- ROS2 control + transmission macros -->
  <xacro:include filename="$(find fw_mini_description)/urdf/macros.xacro" />

  <!-- Gazebo plugins (materials, sensors, ros2_control plugin) -->
  <xacro:include filename="$(find fw_mini_description)/urdf/fw_mini.gazebo.xacro" />

  <!-- ========================= -->
  <!-- Base links                -->
  <!-- ========================= -->
  <link name="base_footprint"/>

  <link name="base_link">
    <visual>
      <geometry>
        <mesh filename="${mesh_path}/fw-mini-chassis.STL" scale="1 1 1"/>
      </geometry>
      <origin xyz="0.2475 0.19 0.07" rpy="1.57 0 -1.57"/>
      <material name="white">
        <color rgba="1 1 1 1"/>
      </material>
    </visual>
    <collision>
      <geometry>
        <box size="0.495 0.36 0.1"/>
      </geometry>
      <origin xyz="0.0 0.0 0.0" rpy="0.0 0.0 0.0"/>
    </collision>
    <inertial>
      <origin xyz="0 0 0"/>
      <mass value="20"/>
      <inertia ixx="0.132" ixy="0" ixz="0" iyy="0.147" iyz="0" izz="0.0182"/>
    </inertial>
  </link>

  <joint name="base_link2base_footprint" type="fixed">
    <parent link="base_footprint"/>
    <child link="base_link"/>
    <origin xyz="0 0 0.032"/>
  </joint>

  <!-- ========================= -->
  <!-- IMU frame                 -->
  <!-- ========================= -->
  <link name="sensor"/>
  <joint name="imu_joint" type="fixed">
    <origin xyz="0 0 0.30" rpy="0 0 0"/>
    <parent link="base_link"/>
    <child link="sensor"/>
  </joint>

  <!-- ========================= -->
  <!-- Livox frame               -->
  <!-- ========================= -->
  <link name="livox_frame"/>
  <joint name="livox_lidar_joint" type="fixed">
    <origin xyz="0 0 0.22" rpy="0 0 0"/>
    <parent link="base_link"/>
    <child link="livox_frame"/>
  </joint>

  <!-- ========================= -->
  <!-- Front-left steering + wheel -->
  <!-- ========================= -->
  <link name="left_steering_hinge">
    <visual>
      <geometry><cylinder radius="0.02" length="0.005"/></geometry>
      <origin xyz="0 0 0" rpy="1.57 0 0"/>
      <material name="black"><color rgba="0 0 0 1"/></material>
    </visual>
    <collision>
      <geometry><cylinder radius="0.01" length="0.005"/></geometry>
      <origin xyz="0 0 0" rpy="1.57 0 0"/>
    </collision>
    <inertial>
      <origin xyz="0 0 0"/>
      <mass value="1"/>
      <inertia ixx="2.7e-5" ixy="0" ixz="0" iyy="2.7e-5" iyz="0" izz="5e-5"/>
    </inertial>
  </link>

  <joint name="left_steering_hinge_joint" type="revolute">
    <parent link="base_link"/>
    <child link="left_steering_hinge"/>
    <origin xyz="0.175 0.125 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-1.57" upper="1.57" effort="10.0" velocity="50.0"/>
  </joint>

  <link name="left_front_wheel">
    <visual>
      <geometry>
        <mesh filename="${mesh_path}/fw-mini-luntai.STL" scale="1 1 1"/>
      </geometry>
      <origin xyz="0.073 -0.305 0.425" rpy="1.57 1.57 -3.14"/>
      <material name="black"><color rgba="0 0 0 1"/></material>
    </visual>
    <collision>
      <geometry><cylinder radius="0.07" length="0.05"/></geometry>
      <origin xyz="0 0 0" rpy="1.57 0 0"/>
    </collision>
    <inertial>
      <origin xyz="0 0 0"/>
      <mass value="4"/>
      <inertia ixx="0.01603" ixy="0" ixz="0" iyy="0.01603" iyz="0" izz="0.0288"/>
    </inertial>
  </link>

  <joint name="left_front_wheel_joint" type="continuous">
    <parent link="left_steering_hinge"/>
    <child link="left_front_wheel"/>
    <origin xyz="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit effort="10" velocity="1000"/>
  </joint>

  <!-- ========================= -->
  <!-- Front-right steering + wheel -->
  <!-- ========================= -->
  <link name="right_steering_hinge">
    <visual>
      <geometry><cylinder radius="0.02" length="0.005"/></geometry>
      <origin xyz="0 0 0" rpy="1.57 0 0"/>
      <material name="black"><color rgba="0 0 0 1"/></material>
    </visual>
    <collision>
      <geometry><cylinder radius="0.01" length="0.005"/></geometry>
      <origin xyz="0 0 0" rpy="1.57 0 0"/>
    </collision>
    <inertial>
      <origin xyz="0 0 0"/>
      <mass value="1"/>
      <inertia ixx="2.7e-5" ixy="0" ixz="0" iyy="2.7e-5" iyz="0" izz="5e-5"/>
    </inertial>
  </link>

  <joint name="right_steering_hinge_joint" type="revolute">
    <parent link="base_link"/>
    <child link="right_steering_hinge"/>
    <origin xyz="0.175 -0.125 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-1.57" upper="1.57" effort="10.0" velocity="50.0"/>
  </joint>

  <link name="right_front_wheel">
    <visual>
      <geometry>
        <mesh filename="${mesh_path}/fw-mini-luntai.STL" scale="1 1 1"/>
      </geometry>
      <origin xyz="-0.073 0.305 0.425" rpy="1.57 1.57 0"/>
      <material name="black"><color rgba="0 0 0 1"/></material>
    </visual>
    <collision>
      <geometry><cylinder radius="0.07" length="0.05"/></geometry>
      <origin xyz="0 0 0" rpy="1.57 0 0"/>
    </collision>
    <inertial>
      <origin xyz="0 0 0"/>
      <mass value="4"/>
      <inertia ixx="0.01603" ixy="0" ixz="0" iyy="0.01603" iyz="0" izz="0.0288"/>
    </inertial>
  </link>

  <joint name="right_front_wheel_joint" type="continuous">
    <parent link="right_steering_hinge"/>
    <child link="right_front_wheel"/>
    <origin xyz="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit effort="10" velocity="1000"/>
  </joint>

  <!-- ========================= -->
  <!-- Rear-left steering + wheel -->
  <!-- ========================= -->
  <link name="rear_left_steering_hinge">
    <visual>
      <geometry><cylinder radius="0.02" length="0.005"/></geometry>
      <origin xyz="0 0 0" rpy="1.57 0 0"/>
      <material name="black"><color rgba="0 0 0 1"/></material>
    </visual>
    <collision>
      <geometry><cylinder radius="0.01" length="0.005"/></geometry>
      <origin xyz="0 0 0" rpy="1.57 0 0"/>
    </collision>
    <inertial>
      <origin xyz="0 0 0"/>
      <mass value="1"/>
      <inertia ixx="2.7e-5" ixy="0" ixz="0" iyy="2.7e-5" iyz="0" izz="5e-5"/>
    </inertial>
  </link>

  <joint name="rear_left_steering_hinge_joint" type="revolute">
    <parent link="base_link"/>
    <child link="rear_left_steering_hinge"/>
    <origin xyz="-0.175 0.125 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-1.57" upper="1.57" effort="10.0" velocity="50.0"/>
  </joint>

  <link name="left_rear_wheel">
    <visual>
      <geometry>
        <mesh filename="${mesh_path}/fw-mini-luntai.STL" scale="1 1 1"/>
      </geometry>
      <origin xyz="0.073 -0.305 0.425" rpy="1.57 1.57 3.14"/>
      <material name="black"><color rgba="0 0 0 1"/></material>
    </visual>
    <collision>
      <geometry><cylinder radius="0.07" length="0.05"/></geometry>
      <origin xyz="0 0 0" rpy="1.57 0 0"/>
    </collision>
    <inertial>
      <origin xyz="0 0 0"/>
      <mass value="4"/>
      <inertia ixx="0.01603" ixy="0" ixz="0" iyy="0.01603" iyz="0" izz="0.0288"/>
    </inertial>
  </link>

  <joint name="left_rear_wheel_joint" type="continuous">
    <parent link="rear_left_steering_hinge"/>
    <child link="left_rear_wheel"/>
    <origin xyz="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit effort="10" velocity="1000"/>
  </joint>

  <!-- ========================= -->
  <!-- Rear-right steering + wheel -->
  <!-- ========================= -->
  <link name="rear_right_steering_hinge">
    <visual>
      <geometry><cylinder radius="0.02" length="0.005"/></geometry>
      <origin xyz="0 0 0" rpy="1.57 0 0"/>
      <material name="black"><color rgba="0 0 0 1"/></material>
    </visual>
    <collision>
      <geometry><cylinder radius="0.01" length="0.005"/></geometry>
      <origin xyz="0 0 0" rpy="1.57 0 0"/>
    </collision>
    <inertial>
      <origin xyz="0 0 0"/>
      <mass value="1"/>
      <inertia ixx="2.7e-5" ixy="0" ixz="0" iyy="2.7e-5" iyz="0" izz="5e-5"/>
    </inertial>
  </link>

  <joint name="rear_right_steering_hinge_joint" type="revolute">
    <parent link="base_link"/>
    <child link="rear_right_steering_hinge"/>
    <origin xyz="-0.175 -0.125 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-1.57" upper="1.57" effort="10.0" velocity="50.0"/>
  </joint>

  <link name="right_rear_wheel">
    <visual>
      <geometry>
        <mesh filename="${mesh_path}/fw-mini-luntai.STL" scale="1 1 1"/>
      </geometry>
      <origin xyz="-0.073 0.305 0.425" rpy="1.57 1.57 0"/>
      <material name="black"><color rgba="0 0 0 1"/></material>
    </visual>
    <collision>
      <geometry><cylinder radius="0.07" length="0.05"/></geometry>
      <origin xyz="0 0 0" rpy="1.57 0 0"/>
    </collision>
    <inertial>
      <origin xyz="0 0 0"/>
      <mass value="4"/>
      <inertia ixx="0.01603" ixy="0" ixz="0" iyy="0.01603" iyz="0" izz="0.0288"/>
    </inertial>
  </link>

  <joint name="right_rear_wheel_joint" type="continuous">
    <parent link="rear_right_steering_hinge"/>
    <child link="right_rear_wheel"/>
    <origin xyz="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit effort="10" velocity="1000"/>
  </joint>

</robot>
